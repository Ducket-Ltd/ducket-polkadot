{
  "name": "ducket-polkadot-contracts",
  "version": "1.0.0",
  "description": "DucketV2 smart contracts for Polkadot Hub",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network polkadotHubTestnet",
